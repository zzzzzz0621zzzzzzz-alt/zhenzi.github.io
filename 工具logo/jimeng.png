糊，锐利速度线，粒子弥散，层次感。一只黑白分明蓬松毛发的超萌熊猫作妖仔，穿着夜行衣身体前倾冲刺突破音障，左手持翠绿竹子长棍被动态模糊覆盖，长棍拉出竹叶型残影形成龙卷风竹叶，从远景延伸至近景特写，长棍划出无数虚影，拨开飞舞的竹叶，一棍横扫划开屏幕形成明显分界线，大量速度线紧贴动作。极致细节，光影交织梦幻朦胧，明暗对比强烈，阴影过渡自然，32K画质，宿命感，唯美意境，帅酷治愈氛围。","image_type":3},"statistic":{"usage_num":21,"favorite_num":371,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"ref_item":{"common_attr":{"id":"7581355948850171162","effect_id":"7581355948850171162","effect_type":9,"description":"","cover_url":"https://p3-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/ea2fa5ff8bae448fa1178a849e15bfdc~tplv-tb4s082cfz-aigc_resize:640:640.jpeg?lk3s=4fa96020\u0026x-expires=1806428943\u0026x-signature=GbSxFb8vPiy92Uc%2BHb4Rqo4qJ3Y%3D","cover_url_map":null,"smart_crop_loc":null,"status":102,"title":"熊猫"},"author":{"name":"INS界","avatar_url":"https://p6-faceu-img-sign.byteimg.com/tos-cn-i-tb4s082cfz/9494c7b5cac541cb960b4b11bdb446c8~tplv-resize:200:200.webp?lk3s=4eecb9e8\u0026x-expires=1777484943\u0026x-signature=rnSCs8KIfOQ5ZTj2U0doZU3OBOQ%3D","uid":"4325919870427204","sec_uid":"MS4wLjABAAAAb81nSTl2E5ZOddFmVP3Vf1s80TxoQix3IvqV4IHEkBvARZonnOmChjzneP7EaNXx","description":"","has_followed":false,"followed_req_uid":false,"status":0,"account_type":0},"feature":"","extra":{"template_type":"image","ai_feature":"text_generate_image"}},"aigc_draft":{"version":"3.0.2","uri":"aigc-draft/5797777687308","content":"{\"type\":\"draft\",\"id\":\"f6085176-9a08-4c3d-a51d-4834defcd77f\",\"min_version\":\"3.0.2\",\"min_features\":[],\"is_from_tsn\":true,\"version\":\"3.0.2\",\"main_component_id\":\"27dc0d5d-0578-44fa-a60f-0689a709e25a\",\"component_list\":[{\"type\":\"image_base_component\",\"id\":\"27dc0d5d-0578-44fa-a60f-0689a709e25a\",\"min_version\":\"3.0.2\",\"aigc_mode\":\"workbench\",\"gen_type\":1,\"metadata\":{\"type\":\"\",\"id\":\"1fac570e-3e9e-408a-9646-15f81112f148\",\"created_platform\":2,\"created_platform_version\":\"1750200\",\"created_time_in_ms\":\"1766226729066\",\"created_did\":\"\"},\"generate_type\":\"generate\",\"abilities\":{\"