eedream 4.0","raw_model_source":"Seedream 4.0"},"feats_cant_combine":[],"model_bg_prompt_starling_key":"","resolution_map":{"2k":{"image_ratio_sizes":[{"ratio_type":1,"width":2048,"height":2048},{"ratio_type":2,"width":1728,"height":2304},{"ratio_type":3,"width":2560,"height":1440},{"ratio_type":4,"width":2304,"height":1728},{"ratio_type":5,"width":1440,"height":2560},{"ratio_type":6,"width":1664,"height":2496},{"ratio_type":7,"width":2496,"height":1664},{"ratio_type":8,"width":3024,"height":1296}],"image_range_config":{"min_length":1296,"max_length":3024,"max_pixel_num":4194304},"resolution_name":"高清 2K"}},"icon_url_svg":"https://p26-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/model-dreamina.svg~tplv-tb4s082cfz-image.image?lk3s=8e790bc3\u0026x-expires=1806428943\u0026x-signature=bTp2ARXEd%2BPOg7Qt0DAomPPYNJc%3D"},"prompt":"在这幅具有恢宏油画效果的作品中，展现的是大明朝风雪中的上朝之路。\n \n极目远眺，天地间一片银白。铅灰色的天空沉重地压下来，与洁白的雪地在遥远的天际线交汇。远处，紫禁城的轮廓在风雪中影影绰绰，高大的宫墙和宫殿的飞檐被白雪覆盖，只隐隐透出威严庄重的气势。\n \n宽阔的御道上，张居正孤独的背影显得那么渺小。他身着红色的朝服，雪花纷纷扬扬地落在上面，却无法掩盖那挺直的脊梁。朝服的红色在洁白的雪地里显得格外深沉，如同他肩负的大明江山的重任。\n \n他迈着沉稳的步伐，一步一步踏在积雪上，身后留下一串深深浅浅的脚印，很快又被新的雪花掩埋。漫天的风雪呼啸着，似要将他单薄的身影吞噬，但他却毫不退缩，坚定地朝着紫禁城的方向前行。\n \n画面整体色调偏冷，以白、灰、黑为主，强化了孤独、冷峻的氛围。细节处，如张居正红色官服被风刮起，雪花的质感，都用细腻笔触精心描绘，营造出高深孤独的意境，展现他在大明复杂局势中，独力支撑的艰难与坚毅。\n整体宏大，庄重，压抑，大师级构图，电影质感","sample_steps":25,"seed":1353940113,"large_image_info":{"height":2560,"width":1440,"resolution_type":"2k"},"sample_strength":0.5},"template_id":"7576206349370019122","aigc_mode":"workbench","insta_drag_params":{"origin_item_id":null},"hide_ref_images":false,"reference_prompt":"恢宏油画风格，冷色调，白、灰、黑为主色，电影质感，大师级构图。天地间银白一片，铅灰色天空压向雪地，远处紫禁城轮廓影绰，宫墙与飞檐被白雪覆盖。宽阔御道上，张居正穿红色朝服，孤独背影渺小，朝服红在雪地深沉，雪花落其上。他迈沉稳步伐踏积雪，身后脚印被新雪掩埋，风雪呼啸似吞噬其身影，朝服被风刮起，雪花质感细腻。画面宏大、庄重、压抑，强化孤独冷峻氛围，营造高深孤独意境，展现张居正独力支撑大明的艰难与坚毅。","image_type":3},"statistic":{"usage_num":31,"favorite_num":310,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"ref_item":{"common_attr":{"id":"7576206349370019122","effect_id":"7576206349370019122","effect_type":9,"descrip