。\\n \\n他迈着沉稳的步伐，一步一步踏在积雪上，身后留下一串深深浅浅的脚印，很快又被新的雪花掩埋。漫天的风雪呼啸着，似要将他单薄的身影吞噬，但他却毫不退缩，坚定地朝着紫禁城的方向前行。\\n \\n画面整体色调偏冷，以白、灰、黑为主，强化了孤独、冷峻的氛围。细节处，如张居正红色官服被风刮起，雪花的质感，都用细腻笔触精心描绘，营造出高深孤独的意境，展现他在大明复杂局势中，独力支撑的艰难与坚毅。\\n整体宏大，庄重，压抑，大师级构图，电影质感\",\"seed\":1353940113,\"sample_strength\":0.3,\"image_ratio\":5,\"large_image_info\":{\"type\":\"\",\"id\":\"19ba24ac-2866-4cf4-952b-6b41026a8f8b\",\"height\":2560,\"width\":1440,\"format\":\"jpg\",\"resolution_type\":\"2k\"}}},\"gen_option\":{\"type\":\"\",\"id\":\"9ba4bbf4-3745-494d-8d06-bc16817ca70a\",\"is_need_confirm\":false}}}]}","update_time":0,"last_preview_time":0,"resource_type":"","public_uri":"","variables":null,"resource_width":0,"resource_height":0,"node_keys":null,"cost":0},"extra":{"template_type":"image","ai_feature":"text_generate_image"},"ai_feature":{"features":[{"type":"text_generate_image"}],"is_merged":true},"sharing_info":{"share_status":3},"metadata_param":"{\"effect_id\":\"7576206349370019122\",\"effect_type\":\"template\"}"},{"common_attr":{"id":"7619527624208960818","effect_id":"7619527624208960818","effect_type":9,"title":"宇宙运输舰","description":"","cover_url":"https://p26-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/4e9f13443465401ab5d535217a8e9055~tplv-tb4s082cfz-aigc_resize:2048:2048.webp?lk3s=4fa96020\u0026x-expires=1776816000\u0026x-signature=Eu%2FfmKziICuilhUbfnp9x3K3KLE%3D","item_urls":[""],"md5":"","third_resource_id":"7619526877648063782","create_time":1774059524,"status":102,"review_info":{"review_status":100,"review_code_list":[]},"aspect_ratio":0.75,"publish_source":"user_post_mweb_item","collection_ids":[],"extra":"{\"web_rate\":12,\"web_eco_rate\":0,\"eco_rate\":0,\"rate\":12}","has_published":true,"published_item_id":"7619527624208960818","cover_url_map":{"1080":"https://p3-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/4e9f13443465401ab5d535217a8e9055~tplv-tb4s082cfz-aigc_resize_loss:1080:1080.webp?lk3s=4fa96020\u0026x-expires=1776816000\u0026x-signature=VLow6hYsrPNLCq98XoBnasZtsjQ%3D","2400":"https://p